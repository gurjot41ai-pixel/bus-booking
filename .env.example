# ─────────────────────────────────────────────────────────────────────────────
# BusGo — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV:  Copy this file to .env  →  never commit .env to git
# RAILWAY:    Set each variable below in Railway → your service → Variables tab
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — generate a secure key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-secret-key-here

# Set to False in production, True only for local dev
DEBUG=False

# Comma-separated allowed hostnames (Railway sets your subdomain automatically)
ALLOWED_HOSTS=*.railway.app,*.up.railway.app,localhost,127.0.0.1

# Optional: your custom domain (e.g. https://busgo.com)
# CUSTOM_DOMAIN=https://busgo.com

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL
# On Railway: add a PostgreSQL plugin to your project. Railway will
# automatically inject ALL of the PGHOST/PGPORT/etc variables below
# into your service. You do NOT need to set them manually on Railway.
#
# For local dev, fill these in to point to your local Postgres instance:
# ─────────────────────────────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=busgo
PGUSER=postgres
PGPASSWORD=yourpassword

# Optional: Django log level (DEBUG, INFO, WARNING, ERROR)
DJANGO_LOG_LEVEL=INFO
