# ─────────────────────────────────────────────────────────
# BusGo — Environment Variables
# Copy this file to .env for local dev (never commit .env)
# Set these as Railway environment variables in production
# ─────────────────────────────────────────────────────────

# REQUIRED — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-secret-key-here

# Set to False in production, True for local dev
DEBUG=False

# Comma-separated list of allowed hostnames (or * for any)
ALLOWED_HOSTS=*.railway.app,*.up.railway.app,localhost

# Optional: your custom domain (e.g. https://busgo.com)
# CUSTOM_DOMAIN=https://busgo.com

# Auto-set by Railway when you add a PostgreSQL plugin — do not set manually on Railway
# For local dev, set this to your local Postgres URL, or leave unset to use SQLite
# DATABASE_URL=postgres://user:password@localhost:5432/busgo

# Optional: Django log level (DEBUG, INFO, WARNING, ERROR)
DJANGO_LOG_LEVEL=INFO
